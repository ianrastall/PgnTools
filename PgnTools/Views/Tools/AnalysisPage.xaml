<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="PgnTools.Views.Tools.AnalysisPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:views="using:PgnTools.Views.Tools"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d" NavigationCacheMode="Disabled">

    <Grid Padding="0,0,0,24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Spacing="8" Margin="0,0,0,16">
            <TextBlock Text="Analysis" Style="{StaticResource TitleTextBlockStyle}"/>
            <TextBlock Text="Inspect PGN statistics, run engine analysis, compute Elegance scores, and filter for checkmates."
                       Style="{StaticResource BodyTextBlockStyle}"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap"/>
        </StackPanel>

        <Pivot Grid.Row="1">
            <PivotItem Header="PGN Info">
                <views:PgnInfoView ViewModel="{x:Bind ViewModel.PgnInfo}"/>
            </PivotItem>
            <PivotItem Header="Chess Analyzer">
                <views:ChessAnalyzerView ViewModel="{x:Bind ViewModel.ChessAnalyzer}"/>
            </PivotItem>
            <PivotItem Header="Elegance">
                <views:EleganceView ViewModel="{x:Bind ViewModel.Elegance}"/>
            </PivotItem>
            <PivotItem Header="Checkmate Filter">
                <views:CheckmateFilterView ViewModel="{x:Bind ViewModel.CheckmateFilter}"/>
            </PivotItem>
        </Pivot>
    </Grid>
</Page>
