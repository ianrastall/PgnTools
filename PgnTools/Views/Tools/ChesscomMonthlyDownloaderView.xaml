<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="PgnTools.Views.Tools.ChesscomMonthlyDownloaderView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Spacing="12" Padding="0,8,0,0">
            <TextBlock Text="Monthly crawl"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>

            <TextBlock Text="Target Month"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
            <StackPanel Orientation="Horizontal" Spacing="12">
                <NumberBox Width="140"
                           Minimum="1900"
                           Maximum="2100"
                           SpinButtonPlacementMode="Inline"
                           Value="{x:Bind ViewModel.TargetYear, Mode=TwoWay}"/>
                <NumberBox Width="100"
                           Minimum="1"
                           Maximum="12"
                           SpinButtonPlacementMode="Inline"
                           Value="{x:Bind ViewModel.TargetMonth, Mode=TwoWay}"/>
                <NumberBox Width="200"
                           Minimum="0"
                           SmallChange="50"
                           SpinButtonPlacementMode="Inline"
                           Value="{x:Bind ViewModel.MinElo, Mode=TwoWay}"/>
            </StackPanel>

            <TextBlock Text="Filters"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
            <CheckBox Content="Exclude bullet games"
                      IsChecked="{x:Bind ViewModel.ExcludeBullet, Mode=TwoWay}"/>

            <TextBlock Text="Seed List"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBox Grid.Column="0"
                         PlaceholderText="Select seed list..."
                         Text="{x:Bind ViewModel.SeedFilePath, Mode=OneWay}"
                         IsReadOnly="True"
                         Margin="0,0,12,0"/>

                <Button Grid.Column="1"
                        Content="Browse..."
                        Command="{x:Bind ViewModel.SelectSeedFileCommand}"/>
            </Grid>

            <TextBlock Text="Processed List"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBox Grid.Column="0"
                         PlaceholderText="Select processed list..."
                         Text="{x:Bind ViewModel.ProcessedFilePath, Mode=OneWay}"
                         IsReadOnly="True"
                         Margin="0,0,12,0"/>

                <Button Grid.Column="1"
                        Content="Browse..."
                        Command="{x:Bind ViewModel.SelectProcessedFileCommand}"/>
            </Grid>

            <TextBlock Text="Output File"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBox Grid.Column="0"
                         PlaceholderText="Select output PGN..."
                         Text="{x:Bind ViewModel.OutputFilePath, Mode=OneWay}"
                         IsReadOnly="True"
                         Margin="0,0,12,0"/>

                <Button Grid.Column="1"
                        Content="Browse..."
                        Command="{x:Bind ViewModel.SelectOutputFileCommand}"/>
            </Grid>

            <CheckBox x:Name="EnableLoggingCheckBox"
                      Content="Write detailed log file"
                      IsChecked="{x:Bind ViewModel.EnableLogging, Mode=TwoWay}"/>

            <TextBlock Text="Log File"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
            <ContentControl x:Name="LogFileContainer">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBox Grid.Column="0"
                             PlaceholderText="Select log file..."
                             Text="{x:Bind ViewModel.LogFilePath, Mode=OneWay}"
                             IsReadOnly="True"
                             Margin="0,0,12,0"/>

                    <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8">
                        <Button Content="Browse..."
                                Command="{x:Bind ViewModel.SelectLogFileCommand}"/>
                        <Button Content="Clear"
                                Command="{x:Bind ViewModel.ClearLogFileCommand}"/>
                    </StackPanel>
                </Grid>
            </ContentControl>

            <StackPanel Orientation="Horizontal" Spacing="12">
                <Button Content="Start Crawl"
                        Command="{x:Bind ViewModel.StartCommand}"/>
                <Button Content="Cancel"
                        Command="{x:Bind ViewModel.CancelCommand}"
                        IsEnabled="{x:Bind ViewModel.IsRunning, Mode=OneWay}"/>
            </StackPanel>

            <TextBlock Text="{x:Bind ViewModel.StatusMessage, Mode=OneWay}"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                       TextWrapping="Wrap"/>
        </StackPanel>
    </ScrollViewer>
</UserControl>
