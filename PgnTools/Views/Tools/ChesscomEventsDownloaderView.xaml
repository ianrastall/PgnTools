<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="PgnTools.Views.Tools.ChesscomEventsDownloaderView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:controls="using:PgnTools.Views.Controls"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Spacing="12" Padding="0,8,0,0">
            <TextBlock Text="Download Chess.com event PGNs by numeric event ID range."
                       Style="{StaticResource BodyTextBlockStyle}"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                       TextWrapping="Wrap"/>

            <TextBlock Text="Event ID Range"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
            <StackPanel Orientation="Horizontal" Spacing="12">
                <NumberBox Width="180"
                           Header="Start ID"
                           Minimum="1"
                           SmallChange="1"
                           SpinButtonPlacementMode="Inline"
                           Value="{x:Bind ViewModel.StartEventId, Mode=TwoWay}"/>
                <NumberBox Width="180"
                           Header="End ID"
                           Minimum="1"
                           SmallChange="1"
                           SpinButtonPlacementMode="Inline"
                           Value="{x:Bind ViewModel.EndEventId, Mode=TwoWay}"/>
            </StackPanel>

            <CheckBox Content="Resume from status CSV"
                      IsChecked="{x:Bind ViewModel.ResumeFromStatus, Mode=TwoWay}"/>

            <CheckBox Content="Infer every-fifth dead IDs from status CSV"
                      IsChecked="{x:Bind ViewModel.InferEveryFifthDeadIds, Mode=TwoWay}"/>

            <NumberBox Width="220"
                       Header="Request Delay (ms)"
                       Minimum="0"
                       Maximum="60000"
                       SmallChange="25"
                       SpinButtonPlacementMode="Inline"
                       Value="{x:Bind ViewModel.RequestDelayMs, Mode=TwoWay}"/>

            <TextBlock Text="Chess.com Session"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
            <StackPanel Orientation="Horizontal" Spacing="12">
                <Button Content="Open Sign In"
                        Click="OpenSignInButton_Click"
                        Style="{StaticResource Action}"
                        IsEnabled="{x:Bind ViewModel.IsRunning, Mode=OneWay, Converter={StaticResource InverseBooleanConverter}}"/>
                <Button Content="Capture Session"
                        Click="CaptureSessionButton_Click"
                        Style="{StaticResource Action}"
                        IsEnabled="{x:Bind ViewModel.IsRunning, Mode=OneWay, Converter={StaticResource InverseBooleanConverter}}"/>
            </StackPanel>
            <TextBlock Text="{x:Bind ViewModel.SessionStatusMessage, Mode=OneWay}"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                       TextWrapping="Wrap"/>
            <WebView2 x:Name="SessionWebView"
                      Height="360"
                      Visibility="Collapsed"/>

            <TextBlock Text="Output File"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBox Grid.Column="0"
                         PlaceholderText="Select output PGN..."
                         Text="{x:Bind ViewModel.OutputFilePath, Mode=OneWay}"
                         IsReadOnly="True"
                         Margin="0,0,12,0"/>

                <Button Grid.Column="1"
                        Content="Browse..."
                        Command="{x:Bind ViewModel.SelectOutputFileCommand}"
                        Style="{StaticResource Action}"/>
            </Grid>

            <TextBlock Text="Titled Tuesday Output File"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBox Grid.Column="0"
                         PlaceholderText="Select Titled Tuesday output PGN..."
                         Text="{x:Bind ViewModel.TitledTuesdayOutputFilePath, Mode=OneWay}"
                         IsReadOnly="True"
                         Margin="0,0,12,0"/>

                <Button Grid.Column="1"
                        Content="Browse..."
                        Command="{x:Bind ViewModel.SelectTitledTuesdayOutputFileCommand}"
                        Style="{StaticResource Action}"/>
            </Grid>

            <TextBlock Text="Status CSV"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBox Grid.Column="0"
                         PlaceholderText="Select status CSV..."
                         Text="{x:Bind ViewModel.StatusFilePath, Mode=OneWay}"
                         IsReadOnly="True"
                         Margin="0,0,12,0"/>

                <Button Grid.Column="1"
                        Content="Browse..."
                        Command="{x:Bind ViewModel.SelectStatusFileCommand}"
                        Style="{StaticResource Action}"/>
            </Grid>

            <StackPanel Orientation="Horizontal" Spacing="12">
                <Button Content="Start Download"
                        Click="StartDownloadButton_Click"
                        Style="{StaticResource PrimaryAction}"
                        IsEnabled="{x:Bind ViewModel.IsRunning, Mode=OneWay, Converter={StaticResource InverseBooleanConverter}}"/>

                <Button Content="Cancel"
                        Command="{x:Bind ViewModel.CancelCommand}"
                        Style="{StaticResource Action}"
                        IsEnabled="{x:Bind ViewModel.IsRunning, Mode=OneWay}"/>
            </StackPanel>

            <controls:ToolStatusBar StatusMessage="{x:Bind ViewModel.StatusMessage, Mode=OneWay}"
                                    StatusSeverity="{x:Bind ViewModel.StatusSeverity, Mode=OneWay}"
                                    StatusDetail="{x:Bind ViewModel.StatusDetail, Mode=OneWay}"
                                    IsRunning="{x:Bind ViewModel.IsRunning, Mode=OneWay}"
                                    IsIndeterminate="False"
                                    ProgressValue="{x:Bind ViewModel.ProgressValue, Mode=OneWay}"/>
        </StackPanel>
    </ScrollViewer>
</UserControl>
