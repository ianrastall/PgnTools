<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="PgnTools.Views.Tools.ChesscomDownloaderPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:views="using:PgnTools.Views.Tools"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d" NavigationCacheMode="Disabled">

    <Grid Padding="0,0,0,24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Spacing="8" Margin="0,0,0,16">
            <TextBlock Text="Chess.com" Style="{StaticResource TitleTextBlockStyle}"/>
            <TextBlock Text="Download Chess.com games by user or crawl a specific month using a seed list."
                       Style="{StaticResource BodyTextBlockStyle}"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                       TextWrapping="Wrap"/>
        </StackPanel>

        <Pivot Grid.Row="1">
            <PivotItem Header="User Archives">
                <views:ChesscomDownloaderView ViewModel="{x:Bind ViewModel.UserDownloader}"/>
            </PivotItem>

            <PivotItem Header="Monthly Crawl">
                <views:ChesscomMonthlyDownloaderView ViewModel="{x:Bind ViewModel.MonthlyDownloader}"/>
            </PivotItem>
        </Pivot>
    </Grid>
</Page>







